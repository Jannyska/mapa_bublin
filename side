const pMap = {}, bMap = {};
DATA.people.forEach(p => pMap[p.id] = p);
DATA.bubbles.forEach(b => bMap[b.id] = b);

function sharedMembers(b1, b2) { return b1.members.filter(m => b2.members.includes(m)); }
function sharedCount(b1, b2) { return sharedMembers(b1, b2).length; }

const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
let W, H, nodes = [], hoveredId = null, selectedBubbleId = null, selectedPersonId = null, searchHighlight = null;

function isDark() { return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches; }

function initLayout() {
  W = canvas.offsetWidth;
  H = Math.round(W * 0.68);
  canvas.width = W * devicePixelRatio;
  canvas.height = H * devicePixelRatio;
  ctx.scale(devicePixelRatio, devicePixelRatio);
  nodes = [];
  const PAD = 56, cols = 6, rows = Math.ceil(DATA.bubbles.length / cols);
  const cellW = (W - PAD*2) / cols, cellH = (H - PAD*2) / rows;
  const jitters = [0.08,-0.12,0.15,-0.07,0.11,-0.09,0.13,-0.14,0.06,-0.10,0.09,-0.11,0.14,-0.08,0.12,-0.06,0.10,-0.13];
  DATA.bubbles.forEach((b, i) => {
    const col = i % cols, row = Math.floor(i / cols);
    const x = PAD + (col + 0.5) * cellW + jitters[i % jitters.length] * cellW;
    const y = PAD + (row + 0.5) * cellH + jitters[(i+3) % jitters.length] * cellH;
    const r = 28 + b.members.length * 2.8;
    nodes.push({ id: b.id, x, y, r, data: b });
  });
  draw();
}

function drawBubble(n, state) {
  const b = n.data, dark = isDark();
  let fill, stroke, lw, alpha = 1;
  if (state === 'hovered')       { fill='#CD2626'; stroke='#791F1F'; lw=2; }
  else if (state === 'selected') { fill='#A32D2D'; stroke='#501313'; lw=2.5; }
  else if (state === 'related')  { fill='#F09595'; stroke='#CD2626'; lw=1.5; }
  else if (state === 'dimmed')   { fill=dark?'#2d1010':'#FCEBEB'; stroke=dark?'#A32D2D':'#F7C1C1'; lw=0.5; alpha=0.3; }
  else                           { fill='#F09595'; stroke='#E24B4A'; lw=0.5; }

  ctx.globalAlpha = alpha;
  ctx.beginPath(); ctx.arc(n.x, n.y, n.r, 0, Math.PI*2);
  ctx.fillStyle = fill; ctx.fill();
  ctx.strokeStyle = stroke; ctx.lineWidth = lw; ctx.stroke();

  if (alpha > 0.5) {
    ctx.beginPath(); ctx.arc(n.x, n.y, n.r + 3.5, 0, Math.PI*2);
    ctx.strokeStyle = '#EF9F27';
    ctx.lineWidth = state === 'selected' ? 2.5 : state === 'hovered' ? 2 : 1;
    ctx.globalAlpha = state === 'selected' ? 1 : state === 'hovered' ? 0.9 : 0.5;
    ctx.stroke();
  }
  ctx.globalAlpha = alpha;

  ctx.fillStyle = '#4A1B0C'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
  const words = b.name.split(' '), fs = Math.max(9, Math.min(12, n.r / 2.8));
  ctx.font = `500 ${fs}px ${getComputedStyle(document.body).fontFamily}`;
  if (words.length === 1) { ctx.fillText(words[0], n.x, n.y); }
  else if (words.length === 2) { ctx.fillText(words[0], n.x, n.y - fs*0.65); ctx.fillText(words[1], n.x, n.y + fs*0.65); }
  else { const mid = Math.ceil(words.length/2); ctx.fillText(words.slice(0,mid).join(' '), n.x, n.y - fs*0.65); ctx.fillText(words.slice(mid).join(' '), n.x, n.y + fs*0.65); }

  ctx.globalAlpha = alpha;
  const bx = n.x + n.r*0.66, by = n.y - n.r*0.66;
  ctx.beginPath(); ctx.arc(bx, by, 9, 0, Math.PI*2); ctx.fillStyle='#791F1F'; ctx.fill();
  ctx.font = `500 9px ${getComputedStyle(document.body).fontFamily}`; ctx.fillStyle='#FCEBEB';
  ctx.fillText(b.members.length, bx, by);
  ctx.globalAlpha = 1;
}

function draw() {
  ctx.clearRect(0, 0, W, H);
  const dark = isDark(), activeBid = selectedBubbleId || hoveredId;
  DATA.bubbles.forEach((b1, i) => {
    DATA.bubbles.forEach((b2, j) => {
      if (j <= i) return;
      const shared = sharedCount(b1, b2);
      if (activeBid) { if (b1.id !== activeBid && b2.id !== activeBid) return; if (shared < 1) return; }
      else { if (shared < 2) return; }
      const n1 = nodes[i], n2 = nodes[j];
      ctx.beginPath(); ctx.moveTo(n1.x, n1.y); ctx.lineTo(n2.x, n2.y);
      if (activeBid && (b1.id === activeBid || b2.id === activeBid)) {
        ctx.strokeStyle='#F09595'; ctx.lineWidth=shared*1.3; ctx.globalAlpha=0.3+shared*0.08;
      } else {
        ctx.strokeStyle=dark?'#2C2C2A':'#D3D1C7'; ctx.lineWidth=shared*0.5; ctx.globalAlpha=0.5;
      }
      ctx.stroke(); ctx.globalAlpha=1;
    });
  });
  nodes.forEach(n => {
    let state = 'normal';
    if (searchHighlight) {
      const b = n.data;
      state = (b.name.toLowerCase().includes(searchHighlight) || b.members.some(mid => pMap[mid].name.toLowerCase().includes(searchHighlight))) ? 'related' : 'dimmed';
    } else if (selectedBubbleId) {
      if (n.id === selectedBubbleId) state = 'selected';
      else state = sharedCount(bMap[selectedBubbleId], n.data) > 0 ? 'related' : 'dimmed';
    } else if (hoveredId) {
      if (n.id === hoveredId) state = 'hovered';
      else state = sharedCount(bMap[hoveredId], n.data) > 0 ? 'normal' : 'dimmed';
    }
    drawBubble(n, state);
  });
}

function nodeAt(mx, my) {
  for (let i = nodes.length-1; i >= 0; i--) {
    const n = nodes[i], dx = mx-n.x, dy = my-n.y;
    if (dx*dx+dy*dy <= (n.r+4)*(n.r+4)) return n;
  }
  return null;
}

canvas.addEventListener('mousemove', e => {
  const rect = canvas.getBoundingClientRect();
  const n = nodeAt(e.clientX - rect.left, e.clientY - rect.top);
  const tip = document.getElementById('tooltip');
  if (n) {
    canvas.style.cursor = 'pointer';
    const b = n.data, leader = pMap[b.leaderId];
    const chips = b.members.map(mid => {
      const p = pMap[mid], cls = mid === b.leaderId ? 'chip leader' : 'chip';
      return `<span class="${cls}">${p.name}${mid===b.leaderId?' ★':''}</span>`;
    }).join('');
    tip.innerHTML = `<div class="tip-title">${b.name}</div><div class="tip-leader">★ ${leader.name}</div><div style="color:var(--text-secondary);font-size:11px;margin-bottom:3px">${b.members.length} členů:</div><div class="tip-members">${chips}</div>`;
    tip.style.display = 'block';
    let tx = e.clientX+14, ty = e.clientY-10;
    if (tx+270 > window.innerWidth-10) tx = e.clientX-274;
    if (ty+150 > window.innerHeight-10) ty = e.clientY-150;
    tip.style.left = tx+'px'; tip.style.top = ty+'px';
    if (hoveredId !== n.id) { hoveredId = n.id; draw(); }
  } else {
    canvas.style.cursor = 'default'; tip.style.display = 'none';
    if (hoveredId) { hoveredId = null; draw(); }
  }
});

canvas.addEventListener('mouseleave', () => {
  document.getElementById('tooltip').style.display = 'none';
  hoveredId = null; draw();
});

canvas.addEventListener('click', e => {
  const rect = canvas.getBoundingClientRect();
  const n = nodeAt(e.clientX - rect.left, e.clientY - rect.top);
  if (!n) {
    selectedBubbleId = null; selectedPersonId = null;
    document.getElementById('detail').innerHTML = 'Najeď na bublinu pro náhled členů, klikni pro detail.';
    document.getElementById('person-detail').style.display = 'none';
    draw(); return;
  }
  selectedBubbleId = n.id; selectedPersonId = null;
  document.getElementById('person-detail').style.display = 'none';
  renderBubbleDetail(n.data);
  draw();
});

function renderBubbleDetail(b) {
  const leader = pMap[b.leaderId];
  const memberChips = b.members.map(mid => {
    const p = pMap[mid], isLeader = mid === b.leaderId;
    const activeClass = selectedPersonId === mid ? ' active' : '';
    return `<span class="chip clickable${isLeader?' leader':''}${activeClass}" onclick="selectPerson('${mid}')">${p.name}${isLeader?' ★':''}</span>`;
  }).join('');
  const sharedBlocks = DATA.bubbles
    .filter(b2 => b2.id !== b.id && sharedCount(b, b2) > 0)
    .sort((a, b2) => sharedCount(b, b2) - sharedCount(b, a))
    .map(b2 => {
      const shared = sharedMembers(b, b2);
      const names = shared.map(mid => pMap[mid].name).join(', ');
      return `<div class="shared-block"><div class="sb-title">${b2.name} <span style="font-weight:400;color:var(--text-secondary)">(${shared.length})</span></div><div class="sb-names">${names}</div></div>`;
    }).join('');
  document.getElementById('detail').innerHTML = `
    <div class="det-title">${b.name}</div>
    <div class="det-sub">Leader: <strong>${leader.name}</strong> · ${b.members.length} členů · klikni na člena pro jeho bubliny</div>
    <div class="det-members">${memberChips}</div>
    ${sharedBlocks ? `<div class="section-label">Sdílí členy s</div>${sharedBlocks}` : ''}
  `;
}

function selectPerson(pid) {
  selectedPersonId = pid;
  if (selectedBubbleId) renderBubbleDetail(bMap[selectedBubbleId]);
  const p = pMap[pid];
  const myBubbles = DATA.bubbles.filter(b => b.members.includes(pid));
  const asLeader = myBubbles.filter(b => b.leaderId === pid);
  const bChips = myBubbles.map(b => {
    const isLeader = b.leaderId === pid;
    return `<span class="chip${isLeader?' leader':''}">${b.name}${isLeader?' ★':''}</span>`;
  }).join('');
  const pd = document.getElementById('person-detail');
  pd.style.display = 'block';
  pd.innerHTML = `
    <div class="pd-name">${p.name}</div>
    <div class="pd-sub">${myBubbles.length} bublin · ${asLeader.length > 0 ? `leader v ${asLeader.length}` : 'není leader'}</div>
    <div class="pd-bubbles">${bChips}</div>
  `;
  pd.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function onSearch(val) { searchHighlight = val.trim().toLowerCase() || null; draw(); }

window.addEventListener('resize', initLayout);
initLayout();
</script>
