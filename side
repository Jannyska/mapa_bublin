      --bg-primary: #ffffff;
      --bg-secondary: #f1efe8;
      --bg-warning: #faeeda;
      --bg-info: #e6f1fb;
      --text-primary: #2c2c2a;
      --text-secondary: #5f5e5a;
      --text-tertiary: #888780;
      --text-warning: #854f0b;
      --text-info: #185fa5;
      --border-secondary: rgba(44,44,42,0.3);
      --border-tertiary: rgba(44,44,42,0.15);
      --border-warning: rgba(133,79,11,0.35);
      --border-info: rgba(24,95,165,0.35);
      --radius-md: 8px;
      --radius-lg: 12px;
      --font: system-ui, -apple-system, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg-primary: #1a1a18;
        --bg-secondary: #2c2c2a;
        --bg-warning: #412402;
        --bg-info: #042c53;
        --text-primary: #e8e6dc;
        --text-secondary: #b4b2a9;
        --text-tertiary: #888780;
        --text-warning: #fac775;
        --text-info: #85b7eb;
        --border-secondary: rgba(232,230,220,0.3);
        --border-tertiary: rgba(232,230,220,0.15);
        --border-warning: rgba(250,199,117,0.35);
        --border-info: rgba(133,183,235,0.35);
      }
    }

    body {
      font-family: var(--font);
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 20px 16px 40px;
    }

    h1 {
      font-size: 20px;
      font-weight: 500;
      margin-bottom: 4px;
      color: var(--text-primary);
    }

    .subtitle {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 16px;
    }

    #controls {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px;
      align-items: center;
    }

    #search {
      flex: 1;
      min-width: 160px;
      font-size: 13px;
      font-family: var(--font);
      padding: 6px 12px;
      border: 0.5px solid var(--border-secondary);
      border-radius: var(--radius-md);
      background: var(--bg-primary);
      color: var(--text-primary);
      outline: none;
    }

    #search:focus { border-color: var(--text-info); box-shadow: 0 0 0 2px var(--border-info); }

    #legend {
      display: flex;
      gap: 14px;
      font-size: 12px;
      color: var(--text-secondary);
      align-items: center;
      flex-wrap: wrap;
    }

    .leg-item { display: flex; align-items: center; gap: 5px; }
    .leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

    canvas {
      display: block;
      width: 100%;
      border: 0.5px solid var(--border-tertiary);
      border-radius: var(--radius-lg);
      cursor: default;
    }

    #tooltip {
      position: fixed;
      background: var(--bg-primary);
      border: 0.5px solid var(--border-secondary);
      border-radius: var(--radius-md);
      padding: 10px 14px;
      font-size: 12px;
      font-family: var(--font);
      pointer-events: none;
      display: none;
      z-index: 999;
      max-width: 260px;
      color: var(--text-primary);
    }

    #tooltip .tip-title { font-weight: 500; font-size: 13px; margin-bottom: 6px; }
    #tooltip .tip-leader { color: var(--text-warning); font-size: 12px; margin-bottom: 4px; }
    #tooltip .tip-members { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }

    .chip {
      display: inline-flex;
      align-items: center;
      background: var(--bg-secondary);
      border: 0.5px solid var(--border-secondary);
      border-radius: 20px;
      padding: 3px 10px;
      font-size: 12px;
      font-family: var(--font);
      color: var(--text-primary);
      cursor: default;
    }
    .chip.leader { background: var(--bg-warning); border-color: var(--border-warning); color: var(--text-warning); }
    .chip.clickable { cursor: pointer; transition: background 0.15s; }
    .chip.clickable:hover { background: var(--bg-info); border-color: var(--border-info); color: var(--text-info); }
    .chip.active { background: var(--bg-info); border-color: var(--border-info); color: var(--text-info); }

    #person-detail {
      margin-top: 10px;
      background: var(--bg-primary);
      border: 0.5px solid var(--border-secondary);
      border-radius: var(--radius-md);
      padding: 14px 16px;
      display: none;
      font-family: var(--font);
    }
    #person-detail .pd-name { font-weight: 500; font-size: 14px; color: var(--text-primary); margin-bottom: 4px; }
    #person-detail .pd-sub { font-size: 12px; color: var(--text-secondary); margin-bottom: 10px; }
    #person-detail .pd-bubbles { display: flex; flex-wrap: wrap; gap: 6px; }

    #detail {
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      padding: 14px 16px;
      margin-top: 10px;
      font-size: 13px;
      font-family: var(--font);
      min-height: 56px;
      color: var(--text-secondary);
      line-height: 1.5;
    }
    #detail .det-title { font-weight: 500; color: var(--text-primary); margin-bottom: 4px; font-size: 14px; }
    #detail .det-sub { color: var(--text-secondary); font-size: 12px; margin-bottom: 10px; }
    #detail .det-members { display: flex; flex-wrap: wrap; gap: 6px; }
    #detail .section-label {
      font-size: 11px;
      color: var(--text-tertiary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 12px 0 6px;
    }

    .shared-block {
      margin-top: 6px;
      padding: 8px 10px;
      background: var(--bg-primary);
      border: 0.5px solid var(--border-tertiary);
      border-radius: var(--radius-md);
    }
    .shared-block .sb-title { font-size: 12px; font-weight: 500; color: var(--text-primary); margin-bottom: 4px; }
    .shared-block .sb-names { font-size: 11px; color: var(--text-secondary); }

    @media (max-width: 500px) {
      body { padding: 12px 10px 32px; }
      h1 { font-size: 17px; }
    }
  </style>
</head>
